<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Book an Appointment</title>
    <meta name="description" content="Book your appointment online — fast and easy.">
    <meta property="og:type" content="website">
    <meta property="og:title" id="og_title" content="Book an Appointment">
    <meta property="og:description" id="og_desc" content="Book your next appointment online.">
    <meta property="og:image" id="og_image" content="">
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link href="https://fonts.googleapis.com/css2?family=DM+Sans:wght@400;500;600;700&family=Fraunces:opsz,wght@9..144,400;9..144,600&display=swap" rel="stylesheet">
    <style>
        *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }
        :root {
            --bg: #FAF8F5; --surface: #fff; --primary: #2D2A26;
            --accent: #8B6F4E; --accent-bg: #F3EDE4; --accent-light: #C4A882;
            --muted: #7A756E; --border: #E8E3DC;
            --radius: 16px; --shadow: 0 8px 40px rgba(45,42,38,.12);
            --font: 'DM Sans', sans-serif; --font-display: 'Fraunces', Georgia, serif;
        }
        html { font-size: 16px; }
        body {
            font-family: var(--font); background: var(--bg); color: var(--primary);
            min-height: 100dvh; display: flex; align-items: center; justify-content: center;
            padding: 24px 16px;
        }
        .card {
            background: var(--surface); border-radius: var(--radius);
            box-shadow: var(--shadow); max-width: 420px; width: 100%;
            overflow: hidden;
        }
        .card-hero {
            background: linear-gradient(135deg, var(--accent), var(--accent-light));
            padding: 32px 24px 24px; text-align: center; position: relative;
        }
        .provider-photo {
            width: 88px; height: 88px; border-radius: 50%;
            border: 3px solid rgba(255,255,255,.5);
            object-fit: cover; display: block; margin: 0 auto 12px;
        }
        .provider-photo-placeholder {
            width: 88px; height: 88px; border-radius: 50%;
            background: rgba(255,255,255,.2); border: 3px solid rgba(255,255,255,.4);
            display: flex; align-items: center; justify-content: center;
            margin: 0 auto 12px; font-size: 2rem;
        }
        .business-name {
            font-family: var(--font-display); font-size: 1.5rem; font-weight: 600;
            color: #fff; letter-spacing: -.02em; margin-bottom: 4px;
        }
        .business-bio {
            font-size: .875rem; color: rgba(255,255,255,.85); line-height: 1.5;
        }
        .card-body { padding: 24px; }
        .section-label {
            font-size: .72rem; font-weight: 700; text-transform: uppercase;
            letter-spacing: .08em; color: var(--muted); margin-bottom: 12px;
        }
        .service-item {
            display: flex; justify-content: space-between; align-items: center;
            padding: 10px 0; border-bottom: 1px solid var(--border);
        }
        .service-item:last-child { border-bottom: none; }
        .svc-name { font-weight: 600; font-size: .9rem; }
        .svc-meta { font-size: .78rem; color: var(--muted); margin-top: 2px; }
        .svc-price { font-weight: 600; color: var(--accent); font-size: .85rem; }
        .next-slot {
            margin-top: 20px; padding: 14px 16px;
            background: var(--accent-bg); border-radius: 10px;
            display: flex; align-items: center; gap: 12px;
        }
        .slot-icon { font-size: 1.4rem; }
        .slot-label { font-size: .75rem; color: var(--muted); font-weight: 600; text-transform: uppercase; letter-spacing: .05em; }
        .slot-time { font-weight: 700; font-size: .95rem; color: var(--primary); margin-top: 2px; }
        .btn-book {
            display: block; width: 100%; margin-top: 20px;
            background: var(--primary); color: #fff;
            border: none; border-radius: 12px; padding: 16px;
            font-family: var(--font); font-size: 1rem; font-weight: 700;
            cursor: pointer; text-decoration: none; text-align: center;
            transition: all .15s ease; letter-spacing: -.01em;
        }
        .btn-book:hover { background: var(--accent); transform: translateY(-1px); }
        .btn-book:active { transform: scale(.97); }
        .socials {
            display: flex; justify-content: center; gap: 16px;
            margin-top: 20px; padding-top: 20px; border-top: 1px solid var(--border);
        }
        .socials a { font-size: 1.3rem; text-decoration: none; transition: transform .15s; }
        .socials a:hover { transform: scale(1.2); }
        .location { font-size: .8rem; color: var(--muted); text-align: center; margin-top: 8px; }
        .loading { text-align: center; padding: 60px 24px; color: var(--muted); }
        .error { text-align: center; padding: 40px 24px; color: #c44; font-size: .9rem; }
        .spinner { width: 32px; height: 32px; border: 3px solid var(--border); border-top-color: var(--accent); border-radius: 50%; animation: spin .7s linear infinite; margin: 0 auto 12px; }
        @keyframes spin { to { transform: rotate(360deg); } }
    </style>
</head>
<body>
<div class="card" id="cardRoot">
    <div class="loading"><div class="spinner"></div>Loading...</div>
</div>

<script>
const API_BASE = '/.netlify/functions';
const SLUG = new URLSearchParams(location.search).get('b') || '';

async function init() {
    if (!SLUG) {
        document.getElementById('cardRoot').innerHTML = '<div class="error">No business specified. Add <code>?b=your-slug</code> to the URL.</div>';
        return;
    }

    try {
        const [configRes, availRes] = await Promise.all([
            fetch(`${API_BASE}/public-config?business_slug=${SLUG}`),
            fetch(`${API_BASE}/public-availability`, {
                method: 'POST',
                headers: { 'Content-Type': 'application/json' },
                body: JSON.stringify({
                    business_slug: SLUG,
                    date_from: new Date().toISOString().split('T')[0],
                    date_to: new Date(Date.now() + 14 * 86400000).toISOString().split('T')[0],
                    service_ids: [], add_on_ids: [], is_new_client: false
                })
            })
        ]);

        if (!configRes.ok) throw new Error('Business not found');
        const config = await configRes.json();
        const avail = availRes.ok ? await availRes.json() : {};

        renderCard(config, avail);
    } catch (err) {
        document.getElementById('cardRoot').innerHTML = `<div class="error">Unable to load booking card.<br><small>${err.message}</small></div>`;
    }
}

function renderCard(config, avail) {
    const br = config.branding || {};
    const biz = config.business || {};
    const allServices = config.services || [];

    // Apply branding colors
    const root = document.documentElement.style;
    if (br.color_primary) root.setProperty('--primary', br.color_primary);
    if (br.color_accent) root.setProperty('--accent', br.color_accent);
    if (br.color_accent_light) root.setProperty('--accent-light', br.color_accent_light);
    if (br.color_background) root.setProperty('--bg', br.color_background);
    if (br.color_surface) root.setProperty('--surface', br.color_surface);

    // Title & OG
    const title = biz.name || 'Book an Appointment';
    document.title = `Book with ${title}`;
    document.getElementById('og_title').content = `Book with ${title}`;
    if (br.card_bio) document.getElementById('og_desc').content = br.card_bio;
    if (br.card_photo_url) document.getElementById('og_image').content = br.card_photo_url;

    // Featured services: use card_featured or top 3
    let featuredIds = br.card_featured_service_ids || [];
    if (!Array.isArray(featuredIds)) { try { featuredIds = JSON.parse(featuredIds); } catch { featuredIds = []; } }
    const featured = featuredIds.length > 0
        ? featuredIds.map(id => allServices.find(s => s.id === id)).filter(Boolean).slice(0, 3)
        : allServices.filter(s => !s.is_inquiry_only).slice(0, 3);

    // Next available slot
    const slots = avail.available_slots || [];
    let nextSlotHtml = '';
    if (slots.length > 0) {
        const tz = biz.timezone || 'America/New_York';
        const dt = new Date(slots[0]);
        const slotStr = dt.toLocaleString('en-US', {
            timeZone: tz, weekday: 'short', month: 'short', day: 'numeric',
            hour: 'numeric', minute: '2-digit', hour12: true
        });
        nextSlotHtml = `<div class="next-slot">
            <div class="slot-icon">🗓️</div>
            <div><div class="slot-label">Next Available</div><div class="slot-time">${slotStr}</div></div>
        </div>`;
    }

    // Social links
    const socialDefs = [
        { k: 'social_instagram', i: '📸', l: 'Instagram' },
        { k: 'social_facebook', i: '📘', l: 'Facebook' },
        { k: 'social_tiktok', i: '🎵', l: 'TikTok' },
        { k: 'social_x', i: '𝕏', l: 'X' },
        { k: 'social_google', i: '📍', l: 'Google' },
        { k: 'social_yelp', i: '⭐', l: 'Yelp' },
        { k: 'social_nextdoor', i: '🏘', l: 'Nextdoor' },
        { k: 'social_youtube', i: '▶', l: 'YouTube' }
    ];
    const activeSocials = socialDefs.filter(s => br[s.k]);
    const socialsHtml = activeSocials.length > 0
        ? `<div class="socials">${activeSocials.map(s => `<a href="${esc(br[s.k])}" target="_blank" rel="noopener" title="${s.l}">${s.i}</a>`).join('')}</div>`
        : '';

    // Provider photo
    const photoHtml = br.card_photo_url
        ? `<img src="${esc(br.card_photo_url)}" alt="${esc(biz.name)}" class="provider-photo">`
        : `<div class="provider-photo-placeholder">✨</div>`;

    // Services section
    const svcHtml = featured.length > 0
        ? `<div class="section-label">Services</div>
           ${featured.map(s => `<div class="service-item">
               <div><div class="svc-name">${esc(s.name)}</div><div class="svc-meta">${s.duration_minutes} min</div></div>
               <div class="svc-price">${esc(s.price_display)}</div>
           </div>`).join('')}`
        : '';

    const locationHtml = biz.location_text
        ? `<div class="location">📍 ${esc(biz.location_text)}</div>` : '';

    const bookUrl = `/booking/?b=${SLUG}`;

    document.getElementById('cardRoot').innerHTML = `
        <div class="card-hero">
            ${photoHtml}
            <div class="business-name">${esc(br.card_headline || biz.name)}</div>
            ${br.card_bio ? `<div class="business-bio">${esc(br.card_bio)}</div>` : ''}
        </div>
        <div class="card-body">
            ${svcHtml}
            ${nextSlotHtml}
            <a href="${bookUrl}" class="btn-book">Book Now →</a>
            ${locationHtml}
            ${socialsHtml}
        </div>
    `;
}

function esc(s) {
    if (!s) return '';
    const d = document.createElement('div');
    d.textContent = s;
    return d.innerHTML;
}

init();
</script>
</body>
</html>
