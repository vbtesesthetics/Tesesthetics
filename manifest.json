// functions/public-book.js
// POST /api/public-book
// Creates a booking with server-side validation and double-booking prevention
// NEVER reveals unavailability reasons to customer

const { getSupabase } = require('./utils/supabase');
const {
    jsonResponse, corsHeaders, validateBookingInput,
    rateLimit, getClientIP
} = require('./utils/validate');
const {
    computeTotalDuration, validateSlotAvailable, findNextSuggestions
} = require('./utils/availability');

exports.handler = async (event) => {
    if (event.httpMethod === 'OPTIONS') return corsHeaders();
    if (event.httpMethod !== 'POST') return jsonResponse(405, { error: 'Method not allowed' });

    const ip = getClientIP(event);
    if (!rateLimit(ip)) return jsonResponse(429, { error: 'Too many requests. Please try again shortly.' });

    let body;
    try {
        body = JSON.parse(event.body);
    } catch {
        return jsonResponse(400, { error: 'Invalid request' });
    }

    // Validate inputs
    const errors = validateBookingInput(body);
    if (errors.length > 0) {
        return jsonResponse(400, { error: errors[0], errors });
    }

    try {
        const supabase = getSupabase();

        // Resolve business
        const { data: business } = await supabase
            .from('businesses')
            .select('id, timezone, name, location_text')
            .eq('slug', body.business_slug)
            .single();

        if (!business) return jsonResponse(404, { error: 'Business not found' });
        const businessId = business.id;
        const timezone = business.timezone;

        // Fetch services, add-ons, settings, availability rules, blackouts
        const [servicesRes, addOnsRes, settingsRes, rulesRes, blackoutsRes] = await Promise.all([
            supabase.from('services').select('*').eq('business_id', businessId).in('id', body.service_ids),
            body.add_on_ids?.length
                ? supabase.from('add_ons').select('*').eq('business_id', businessId).in('id', body.add_on_ids)
                : { data: [] },
            supabase.from('settings').select('*').eq('business_id', businessId).single(),
            supabase.from('availability_rules').select('*').eq('business_id', businessId),
            supabase.from('blackout_blocks').select('*').eq('business_id', businessId).eq('is_active', true)
        ]);

        const services = servicesRes.data || [];
        const addOns = addOnsRes.data || [];
        const settings = settingsRes.data || {};

        if (services.length !== body.service_ids.length) {
            return jsonResponse(400, { error: 'One or more selected services are not available' });
        }

        // Check for inquiry-only services
        const inquiryOnly = services.filter(s => s.is_inquiry_only);
        if (inquiryOnly.length > 0) {
            return jsonResponse(400, {
                error: `${inquiryOnly[0].name} requires a consultation. Please contact us to schedule.`
            });
        }

        // Check service exclusions
        if (services.length > 1) {
            const { data: svcExcl } = await supabase.from('service_exclusions')
                .select('service_id_a, service_id_b')
                .eq('business_id', businessId);
            if (svcExcl) {
                for (let i = 0; i < services.length; i++) {
                    for (let j = i + 1; j < services.length; j++) {
                        const blocked = svcExcl.some(e =>
                            (e.service_id_a === services[i].id && e.service_id_b === services[j].id) ||
                            (e.service_id_b === services[i].id && e.service_id_a === services[j].id));
                        if (blocked) {
                            return jsonResponse(400, {
                                error: `${services[i].name} cannot be combined with ${services[j].name}. Please book them separately.`
                            });
                        }
                    }
                }
            }
        }

        // Compute total duration
        const totalDuration = computeTotalDuration(services, addOns, settings, !!body.is_new_client);
        const startAt = new Date(body.chosen_start_at);
        const endAt = new Date(startAt.getTime() + totalDuration * 60000);

        // === CRITICAL: Server-side slot validation (prevents double booking) ===
        const validation = await validateSlotAvailable(supabase, {
            businessId,
            timezone,
            startAt: startAt.toISOString(),
            totalDurationMinutes: totalDuration,
            settings,
            availabilityRules: rulesRes.data || [],
            blackoutBlocks: blackoutsRes.data || []
        });

        if (!validation.valid) {
            // Find alternative times — never explain WHY
            const dateStr = startAt.toISOString().split('T')[0];
            const suggestions = await findNextSuggestions(supabase, {
                businessId,
                timezone,
                startDate: dateStr,
                totalDurationMinutes: totalDuration,
                settings
            }, 5);

            return jsonResponse(409, {
                error: "Sorry, this time isn't currently available.",
                next_suggestions: suggestions,
                allow_request: settings.allow_request_if_no_slots ?? true
            });
        }

        // === Find or create client profile ===
        let clientId = null;
        try {
            const { data: clientResult } = await supabase.rpc('upsert_client', {
                p_business_id: businessId,
                p_name: body.customer_name.trim(),
                p_phone: body.customer_phone?.trim() || null,
                p_email: body.customer_email?.trim() || null,
                p_is_new: !!body.is_new_client
            });
            clientId = clientResult;

            // If a new PIN was provided, hash and store it using SHA256 (matches portal auth)
            if (clientId && body.initial_pin && /^\d{4}$/.test(body.initial_pin)) {
                const crypto = require('crypto');
                const pinHash = crypto.createHash('sha256')
                    .update(body.initial_pin + ':' + clientId)
                    .digest('hex');
                await supabase.from('clients')
                    .update({ pin_hash: pinHash })
                    .eq('id', clientId)
                    .is('pin_hash', null); // Only set if no PIN exists yet
            }
        } catch (e) {
            console.warn('Client upsert failed (non-fatal):', e);
        }

        // === Create booking ===
        const { data: booking, error: bookErr } = await supabase
            .from('bookings')
            .insert({
                business_id: businessId,
                client_id: clientId,
                start_at: startAt.toISOString(),
                end_at: endAt.toISOString(),
                customer_name: body.customer_name.trim(),
                customer_email: body.customer_email?.trim() || null,
                customer_phone: body.customer_phone?.trim() || null,
                is_new_client: !!body.is_new_client,
                status: 'confirmed',
                public_notes_non_medical: body.public_notes_non_medical?.trim() || null,
                utm_source: body.utm_source?.trim()?.slice(0, 100) || null,
                utm_medium: body.utm_medium?.trim()?.slice(0, 100) || null,
                utm_campaign: body.utm_campaign?.trim()?.slice(0, 100) || null
            })
            .select()
            .single();

        if (bookErr) {
            console.error('Booking insert error:', bookErr);
            return jsonResponse(500, { error: 'Unable to create booking. Please try again.' });
        }

        // === Create booking items ===
        const items = [];
        for (const svc of services) {
            items.push({
                booking_id: booking.id,
                item_type: 'service',
                service_id: svc.id,
                add_on_id: null,
                name_snapshot: svc.name,
                price_snapshot: svc.price_display,
                minutes_snapshot: svc.duration_minutes
            });
        }
        for (const addon of addOns) {
            items.push({
                booking_id: booking.id,
                item_type: 'add_on',
                service_id: null,
                add_on_id: addon.id,
                name_snapshot: addon.name,
                price_snapshot: addon.price_display,
                minutes_snapshot: addon.add_minutes
            });
        }

        if (items.length > 0) {
            await supabase.from('booking_items').insert(items);
        }

        // === Create manage token for cancel/reschedule link ===
        let manageToken = null;
        try {
            const { data: tokenData } = await supabase.from('booking_tokens').insert({
                booking_id: booking.id,
                action: 'view',
                expires_at: new Date(endAt.getTime() + 30 * 86400000).toISOString()
            }).select('token').single();
            manageToken = tokenData?.token;
        } catch (e) { console.warn('Token creation failed (non-fatal):', e); }

        // === Instant SMS confirmation (Feature 2) ===
        try {
            const { data: cs } = await supabase.from('comm_settings')
                .select('sms_enabled, twilio_account_sid, twilio_auth_token, twilio_phone_number')
                .eq('business_id', businessId).single();
            if (cs?.sms_enabled && cs.twilio_account_sid && booking.customer_phone) {
                const tz = business.timezone || 'America/New_York';
                const timeStr = startAt.toLocaleString('en-US', {
                    timeZone: tz, weekday: 'short', month: 'short', day: 'numeric',
                    hour: 'numeric', minute: '2-digit', hour12: true
                });
                const svcNames = services.map(s => s.name).join(', ');
                const intakeText = settings.intake_form_url
                    ? ` | Intake: ${settings.intake_form_url}` : '';
                const smsBody = `Booked! ✓ ${business.name}\n${svcNames}\n${timeStr}${intakeText}\nManage: ${process.env.URL || ''}/portal/?b=${body.business_slug}`;
                await fetch(`https://api.twilio.com/2010-04-01/Accounts/${cs.twilio_account_sid}/Messages.json`, {
                    method: 'POST',
                    headers: {
                        'Authorization': 'Basic ' + Buffer.from(`${cs.twilio_account_sid}:${cs.twilio_auth_token}`).toString('base64'),
                        'Content-Type': 'application/x-www-form-urlencoded'
                    },
                    body: new URLSearchParams({ To: booking.customer_phone, From: cs.twilio_phone_number, Body: smsBody })
                }).catch(e => console.warn('Instant SMS failed:', e));
                await supabase.from('message_log').insert({
                    business_id: businessId, booking_id: booking.id, client_id: clientId,
                    channel: 'sms', message_type: 'confirmation', recipient: booking.customer_phone, status: 'sent'
                }).catch(() => {});
            }
        } catch (e) { console.warn('SMS confirmation error (non-fatal):', e); }

        // === Trigger GCal sync (non-blocking) ===
        try {
            const { data: gcal } = await supabase.from('gcal_settings')
                .select('sync_enabled').eq('business_id', businessId).single();
            if (gcal?.sync_enabled) {
                // Fire-and-forget GCal sync
                fetch(`${process.env.URL}/.netlify/functions/gcal-sync`, {
                    method: 'POST',
                    headers: { 'Content-Type': 'application/json' },
                    body: JSON.stringify({ action: 'sync_booking', booking_id: booking.id })
                }).catch(() => {});
            }
        } catch (e) { /* non-fatal */ }

        // === Smart Rebook Suggestion (Feature 4) ===
        let rebookSuggestion = null;
        try {
            const primaryService = services[0];
            if (primaryService?.rebook_days > 0) {
                const suggestedDate = new Date(startAt.getTime() + primaryService.rebook_days * 86400000);
                rebookSuggestion = {
                    service_name: primaryService.name,
                    rebook_days: primaryService.rebook_days,
                    suggested_date: suggestedDate.toISOString().split('T')[0],
                    suggested_date_display: suggestedDate.toLocaleDateString('en-US', {
                        timeZone: timezone, weekday: 'long', month: 'long', day: 'numeric'
                    }),
                    service_id: primaryService.id
                };
            }
        } catch (e) { /* non-fatal */ }

        // === Build confirmation response ===
        const policyLine = settings.add_on_policy_line ||
            "Same-day add-ons aren't guaranteed because we reserve time for each service. If you'd like to add a service, please let us know at least 24 hours before your appointment so we can confirm availability.";

        // Google Calendar link
        const gcalTitle = encodeURIComponent(`Appointment at ${business.name}`);
        const gcalDetails = encodeURIComponent(
            `Services: ${services.map(s => s.name).join(', ')}` +
            (addOns.length ? `\nAdd-ons: ${addOns.map(a => a.name).join(', ')}` : '') +
            `\n\n${policyLine}`
        );
        const gcalLocation = encodeURIComponent(business.location_text || '');
        const gcalStart = startAt.toISOString().replace(/[-:]/g, '').split('.')[0] + 'Z';
        const gcalEnd = endAt.toISOString().replace(/[-:]/g, '').split('.')[0] + 'Z';
        const googleCalUrl = `https://calendar.google.com/calendar/render?action=TEMPLATE&text=${gcalTitle}&dates=${gcalStart}/${gcalEnd}&details=${gcalDetails}&location=${gcalLocation}`;

        // ICS content for Apple Calendar
        const icsContent = [
            'BEGIN:VCALENDAR',
            'VERSION:2.0',
            'PRODID:-//SalonScheduler//EN',
            'BEGIN:VEVENT',
            `DTSTART:${gcalStart}`,
            `DTEND:${gcalEnd}`,
            `SUMMARY:Appointment at ${business.name}`,
            `LOCATION:${business.location_text || ''}`,
            `DESCRIPTION:Services: ${services.map(s => s.name).join(', ')}${addOns.length ? '\\nAdd-ons: ' + addOns.map(a => a.name).join(', ') : ''}`,
            `UID:${booking.id}@salonscheduler`,
            'STATUS:CONFIRMED',
            'END:VEVENT',
            'END:VCALENDAR'
        ].join('\r\n');

        return jsonResponse(201, {
            booking: {
                id: booking.id,
                start_at: booking.start_at,
                end_at: booking.end_at,
                customer_name: booking.customer_name,
                is_new_client: booking.is_new_client,
                status: booking.status
            },
            summary: {
                services: services.map(s => ({ name: s.name, price: s.price_display, minutes: s.duration_minutes })),
                add_ons: addOns.map(a => ({ name: a.name, price: a.price_display, minutes: a.add_minutes })),
                total_duration_minutes: totalDuration,
                business_name: business.name,
                location: business.location_text
            },
            policy_line: policyLine,
            cancellation_policy: settings.cancellation_policy_text || null,
            intake_form_url: settings.intake_form_url || null,
            intake_form_label: settings.intake_form_label || null,
            rebook_suggestion: rebookSuggestion,
            calendar: {
                google_url: googleCalUrl,
                ics_content: icsContent
            },
            manage_token: manageToken
        });
    } catch (err) {
        console.error('Booking error:', err);
        return jsonResponse(500, { error: 'Unable to create booking. Please try again.' });
    }
};
